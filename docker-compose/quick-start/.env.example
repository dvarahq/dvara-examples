# Production-signed envelope from your DVARA account team (DVARA- prefix, Ed25519-signed)
# optional: blank = Community Edition; set a DVARA- envelope for Enterprise
DVARA_LICENSE_KEY=

# rc24+ required secrets — generate each: openssl rand -base64 32
# DVARA_ENCRYPTION_MASTER_PASSWORD: AES-256-GCM key for ENCRYPTED-mode credentials.
#   ESCROW OFFLINE — loss bricks every encrypted provider credential.
DVARA_ENCRYPTION_MASTER_PASSWORD=replace-with-openssl-rand-output
# Two distinct Bearer keys for the actuator chain (must differ):
DVARA_ACTUATOR_API_KEY=replace-with-openssl-rand-output
# Audit HMAC secret — refused on production profiles when blank/default. Mint a stable one:
DVARA_AUDIT_HMAC_SECRET=replace-with-openssl-rand-output
DVARA_ACTUATOR_METRICS_API_KEY=replace-with-different-openssl-rand-output
OPENAI_API_KEY=sk-...
DB_PASSWORD=dvara

# Default is `false` (keyless requests pass through anonymously, no tenant
# attribution). Flip to `true` for any non-evaluation deployment — rejects
# requests without `Authorization: Bearer gw_...` with HTTP 401.
# DVARA_LLM_GATEWAY_REQUIRE_API_KEY=true
