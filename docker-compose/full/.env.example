# Production-signed envelope from your DVARA account team (DVARA- prefix, Ed25519-signed)
GATEWAY_LICENSE_KEY=DVARA-...your-envelope

# rc24+ required secrets — generate each: openssl rand -base64 32
# GATEWAY_ENCRYPTION_MASTER_PASSWORD: AES-256-GCM key for ENCRYPTED-mode credentials.
#   ESCROW OFFLINE — loss bricks every encrypted provider credential.
GATEWAY_ENCRYPTION_MASTER_PASSWORD=replace-with-openssl-rand-output
# Two distinct Bearer keys for the actuator chain (must differ):
GATEWAY_SERVER_API_KEY=replace-with-openssl-rand-output
# Audit HMAC secret — refused on production profiles when blank/default. Mint a stable one:
GATEWAY_AUDIT_HMAC_SECRET=replace-with-openssl-rand-output
GATEWAY_METRICS_API_KEY=replace-with-different-openssl-rand-output
DB_PASSWORD=dvara
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
