# ─────────────────────────────────────────────────────────────────────
# Core secrets (same as quick-start) — required for the stack to boot.
# ─────────────────────────────────────────────────────────────────────

# Production-signed envelope from your DVARA account team (DVARA- prefix, Ed25519-signed)
DVARA_LICENSE_KEY=DVARA-...your-envelope

# rc24+ required secrets — generate each: openssl rand -base64 32
# DVARA_ENCRYPTION_MASTER_PASSWORD: AES-256-GCM key for ENCRYPTED-mode credentials.
#   ESCROW OFFLINE — loss bricks every encrypted provider credential.
DVARA_ENCRYPTION_MASTER_PASSWORD=replace-with-openssl-rand-output

# Two distinct Bearer keys for the actuator chain (must differ):
DVARA_ACTUATOR_API_KEY=replace-with-openssl-rand-output
DVARA_ACTUATOR_METRICS_API_KEY=replace-with-different-openssl-rand-output

# Audit HMAC secret — refused on production profiles when blank/default. Mint a stable one:
DVARA_AUDIT_HMAC_SECRET=replace-with-openssl-rand-output

OPENAI_API_KEY=sk-...
DB_PASSWORD=dvara

# ─────────────────────────────────────────────────────────────────────
# Transactional email — pick ONE of the three transport modes below.
# Common URLs used in the rendered email body apply to all modes.
# ─────────────────────────────────────────────────────────────────────

# Sender address on every outbound. For `resend` transport, the domain
# part MUST be verified at https://resend.com/domains (or use the
# sandbox sender onboarding@resend.dev which skips verification).
DVARA_FLIGHTDECK_EMAIL_FROM=noreply@dvara.local

# Flightdeck base URL embedded in the welcome / password-reset CTAs.
# For local docker-compose, the default localhost URL is correct.
# Switch to your public hostname before any deployment customers
# will see (e.g. https://flightdeck.yourdomain.com).
DVARA_FLIGHTDECK_EMAIL_FLIGHTDECK_URL=http://localhost:8090

# Data-plane URL shown on welcome / check-email pages. Same rule —
# switch to public hostname before customer-facing.
DVARA_FLIGHTDECK_EMAIL_PUBLIC_ENDPOINT_URL=http://localhost:8080/v1

# Docs link in the welcome email footer. Default points at our public
# docs site; override if you ship your own docs portal.
# DVARA_FLIGHTDECK_EMAIL_DOCS_URL=https://dvarahq.com/docs


# ─────────────────────────────────────────────────────────────────────
# MODE 1: `log` (DEFAULT, dev / CI / smoke tests)
# Renders the email body and prints to flightdeck's stdout at INFO.
# Find the /register?token=... link by grepping the logs:
#   docker compose logs dvara-flightdeck | grep -A20 'INVITATION EMAIL'
# ─────────────────────────────────────────────────────────────────────
DVARA_FLIGHTDECK_EMAIL_TRANSPORT=log


# ─────────────────────────────────────────────────────────────────────
# MODE 2: `resend` (recommended for SaaS / customer-facing deployments)
# Set TRANSPORT to `resend` above (comment the `log` line), then:
#
# 1. Sign up at https://resend.com and create an API key (Full access
#    — needs POST /emails + GET /domains).
# 2. Verify your sender domain at https://resend.com/domains. The
#    flightdeck pod refuses to start on a production-class profile
#    if the sender domain is not verified at boot (verify-domain-at-
#    startup defaults to true). For first-day dev you can use the
#    sandbox sender onboarding@resend.dev which skips verification.
# 3. Fill in DVARA_FLIGHTDECK_EMAIL_RESEND_API_KEY below.
# ─────────────────────────────────────────────────────────────────────
# DVARA_FLIGHTDECK_EMAIL_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────
# MODE 3: `smtp` (self-managed / corporate SMTP / SES / SendGrid relay)
# Set TRANSPORT to `smtp` above (comment the `log` line), then:
#
# Standard Spring `spring.mail.*` properties — relaxed-bound from the
# SPRING_MAIL_* env vars below. Defaults are 587 / STARTTLS / auth on.
# ─────────────────────────────────────────────────────────────────────
# SPRING_MAIL_HOST=smtp.yourprovider.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=apikey
# SPRING_MAIL_PASSWORD=your-smtp-password
# SPRING_MAIL_STARTTLS_ENABLE=true
# SPRING_MAIL_AUTH=true


# ─────────────────────────────────────────────────────────────────────
# Delivery durability (#835 PR 4) — all ten knobs are optional. The
# defaults below are what ship out of the box. Uncomment + tune only
# if you have a specific reason (e.g. Resend rate-limit pressure,
# SES SLA matching, aggressive vs gentle backoff).
#
# Default schedule (max-attempts=5 + initial=30000 + max=120000 +
# multiplier=2.0): 0 / +30s / +60s / +120s / +120s ≈ 5m 30s before
# the row lands in DEAD_LETTERED state.
# ─────────────────────────────────────────────────────────────────────
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_ENABLED=true
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_MAX_ATTEMPTS=5
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_INITIAL_BACKOFF_MS=30000
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_MAX_BACKOFF_MS=120000
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_BACKOFF_MULTIPLIER=2.0
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_RETRY_SWEEP_INTERVAL_MS=30000
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_RETRY_SWEEP_BATCH_SIZE=100
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_IDEMPOTENCY_TTL_MINUTES=60
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_DLQ_RETENTION_DAYS=30
# DVARA_FLIGHTDECK_EMAIL_DELIVERY_CLEANUP_CRON=0 0 3 * * *

# Default is `false` (keyless requests pass through anonymously, no tenant
# attribution). Flip to `true` for any non-evaluation deployment — rejects
# requests without `Authorization: Bearer gw_...` with HTTP 401.
# DVARA_LLM_GATEWAY_REQUIRE_API_KEY=true
