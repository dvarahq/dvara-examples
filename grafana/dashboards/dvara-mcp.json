{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "id": null,
  "uid": "dvara-mcp",
  "title": "Dvara — MCP Proxy & Agentic",
  "description": "MCP tool calls, agent sessions, loop detection, and approval gates.",
  "tags": ["dvara", "mcp", "agentic"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(mcp_tool_calls_total, tenant)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      },
      {
        "name": "server_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(mcp_tool_calls_total, server_id)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Tool Calls / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mcp_tool_calls_total{tenant=~\"$tenant\",server_id=~\"$server_id\"}[5m]))", "legendFormat": "" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "P95 Tool Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(mcp_tool_call_latency_seconds_bucket{server_id=~\"$server_id\"}[5m])) by (le))", "legendFormat": "" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Loop Detections (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(mcp_agent_loop_detected_total{tenant=~\"$tenant\"}[1h]))", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Sessions Killed (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(mcp_agent_sessions_killed_total{tenant=~\"$tenant\"}[1h]))", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Approval Requests (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(mcp_approval_requests_total{tenant=~\"$tenant\"}[1h]))", "legendFormat": "" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Injection Detections (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(gateway_mcp_injection_detections_total{tenant=~\"$tenant\"}[1h]))", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Tool Calls by Server",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (server_id) (rate(mcp_tool_calls_total{tenant=~\"$tenant\",server_id=~\"$server_id\"}[5m]))",
          "legendFormat": "{{server_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Tool Latency by Server",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mcp_tool_call_latency_seconds_bucket{server_id=~\"$server_id\"}[5m])) by (le, server_id))",
          "legendFormat": "P95 {{server_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "title": "Loop Detections by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (loop_type) (rate(mcp_agent_loop_detected_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{loop_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 80 } } }
    },
    {
      "title": "Approval Funnel",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mcp_approval_requests_total{tenant=~\"$tenant\"}[5m]))", "legendFormat": "requested" },
        { "expr": "sum(rate(mcp_approval_granted_total{tenant=~\"$tenant\"}[5m]))", "legendFormat": "granted" },
        { "expr": "sum(rate(mcp_approval_denied_total{tenant=~\"$tenant\"}[5m]))", "legendFormat": "denied" },
        { "expr": "sum(rate(mcp_approval_timeout_total{tenant=~\"$tenant\"}[5m]))", "legendFormat": "timeout" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Tool Error Rate by Server",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (server_id) (rate(mcp_tool_calls_total{tenant=~\"$tenant\",server_id=~\"$server_id\",status=~\"error|5..\"}[5m])) / sum by (server_id) (rate(mcp_tool_calls_total{tenant=~\"$tenant\",server_id=~\"$server_id\"}[5m])) * 100",
          "legendFormat": "{{server_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Guardrail Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (category) (rate(gateway_guardrail_blocked_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "blocked: {{category}}"
        },
        {
          "expr": "sum by (category) (rate(gateway_guardrail_flagged_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "flagged: {{category}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 60 } } }
    }
  ]
}
