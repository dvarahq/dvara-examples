{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "id": null,
  "uid": "dvara-overview",
  "title": "Dvara — Gateway Overview",
  "description": "Request volume, latency, error rates, provider health, and token usage for the Meridian AI Gateway.",
  "tags": ["dvara", "ai-gateway", "llm"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(gateway_requests_total, tenant)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(gateway_requests_total, provider)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(gateway_requests_total, model)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Requests / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(gateway_requests_total{tenant=~\"$tenant\",provider=~\"$provider\",model=~\"$model\"}[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "P95 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_latency_seconds_bucket{tenant=~\"$tenant\",provider=~\"$provider\",model=~\"$model\"}[5m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(gateway_requests_total{status=~\"5..\",tenant=~\"$tenant\",provider=~\"$provider\"}[5m])) / sum(rate(gateway_requests_total{tenant=~\"$tenant\",provider=~\"$provider\"}[5m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Tokens / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(gateway_tokens_total{tenant=~\"$tenant\",model=~\"$model\"}[5m])) * 60",
          "legendFormat": "tokens/min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Provider Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(gateway_provider_errors_total{provider=~\"$provider\"}[1h]))",
          "legendFormat": "errors (1h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Cost / hour (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(gateway_cost_dollars_total{tenant=~\"$tenant\"}[5m])) * 3600",
          "legendFormat": "$/hr"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } }
    },
    {
      "title": "Request Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider) (rate(gateway_requests_total{tenant=~\"$tenant\",provider=~\"$provider\",model=~\"$model\"}[5m]))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Latency Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_latency_seconds_bucket{tenant=~\"$tenant\",provider=~\"$provider\",model=~\"$model\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_latency_seconds_bucket{tenant=~\"$tenant\",provider=~\"$provider\",model=~\"$model\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_latency_seconds_bucket{tenant=~\"$tenant\",provider=~\"$provider\",model=~\"$model\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "title": "Error Rate by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider) (rate(gateway_provider_errors_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 80 } } }
    },
    {
      "title": "Token Usage by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (model, direction) (rate(gateway_tokens_total{tenant=~\"$tenant\",model=~\"$model\"}[5m])) * 60",
          "legendFormat": "{{model}} ({{direction}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Retries & Fallbacks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider) (rate(gateway_retries_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "retries: {{provider}}"
        },
        {
          "expr": "sum by (from_provider, to_provider) (rate(gateway_fallbacks_total[5m]))",
          "legendFormat": "fallback: {{from_provider}} → {{to_provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Cost by Provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider) (increase(gateway_cost_dollars_total{tenant=~\"$tenant\"}[1h]))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "title": "Cost by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (model) (increase(gateway_cost_dollars_total{tenant=~\"$tenant\"}[1h]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "title": "Requests by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (status) (rate(gateway_requests_total{tenant=~\"$tenant\",provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Provider Health Table",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider) (increase(gateway_requests_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "requests"
        },
        {
          "expr": "sum by (provider) (increase(gateway_provider_errors_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "errors"
        },
        {
          "expr": "sum by (provider) (increase(gateway_retries_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "retries"
        }
      ],
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #requests": "Requests (5m)",
              "Value #errors": "Errors (5m)",
              "Value #retries": "Retries (5m)"
            }
          }
        }
      ]
    }
  ]
}
