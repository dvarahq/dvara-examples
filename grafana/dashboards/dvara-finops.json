{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "id": null,
  "uid": "dvara-finops",
  "title": "Dvara — FinOps & Budget",
  "description": "Cost tracking, budget enforcement, model downgrades, and anomaly detection.",
  "tags": ["dvara", "finops", "cost"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(gateway_cost_dollars_total, tenant)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Total Cost (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(gateway_cost_dollars_total{tenant=~\"$tenant\"}[24h]))", "legendFormat": "cost" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } }
    },
    {
      "title": "Budget Blocks (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(gateway_budget_blocked_total{tenant=~\"$tenant\"}[24h]))", "legendFormat": "hard blocks" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Soft Alerts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(gateway_budget_soft_alert_total{tenant=~\"$tenant\"}[24h]))", "legendFormat": "soft alerts" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Model Downgrades (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(gateway_model_downgrades_total{tenant=~\"$tenant\"}[24h]))", "legendFormat": "downgrades" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Cost Over Time by Tenant",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tenant) (rate(gateway_cost_dollars_total{tenant=~\"$tenant\"}[5m])) * 3600",
          "legendFormat": "{{tenant}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Cost Over Time by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (model) (rate(gateway_cost_dollars_total{tenant=~\"$tenant\"}[5m])) * 3600",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Budget Events Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(gateway_budget_blocked_total{tenant=~\"$tenant\"}[5m]))", "legendFormat": "hard blocks" },
        { "expr": "sum(rate(gateway_budget_soft_alert_total{tenant=~\"$tenant\"}[5m]))", "legendFormat": "soft alerts" },
        { "expr": "sum(rate(gateway_budget_warning_total{tenant=~\"$tenant\"}[5m]))", "legendFormat": "warnings" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Model Downgrades Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (original_model, downgraded_model) (rate(gateway_model_downgrades_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{original_model}} → {{downgraded_model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 80 } } }
    },
    {
      "title": "Cost Anomalies",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tenant, model) (rate(gateway_cost_anomaly_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{tenant}} / {{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "points", "pointSize": 10 } } }
    }
  ]
}
